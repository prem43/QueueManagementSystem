@model IEnumerable<QueueManagement.Application.DTOs.User.UserDto>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between
            align-items-center mb-4">

    <h2 class="mb-0">
        User Management
    </h2>

    <a asp-action="Create"
       class="btn btn-primary">

        <i class="fa fa-plus"></i>
        Create User

    </a>

</div>

<div class="card shadow">

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-bordered
                         table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>#</th>

                        <th>Full Name</th>

                        <th>Username</th>

                        <th>Email</th>

                        <th>Role</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        int count = 1;

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@count</td>

                                <td>
                                    @item.FullName
                                </td>

                                <td>
                                    @item.UserName
                                </td>

                                <td>
                                    @item.Email
                                </td>

                                <td>

                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">

                                            Admin

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">

                                            Staff

                                        </span>
                                    }

                                </td>

                            </tr>

                            count++;
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="5"
                                class="text-center text-muted">

                                No users found.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>