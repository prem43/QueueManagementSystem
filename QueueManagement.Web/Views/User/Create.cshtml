@model QueueManagement.Application.DTOs.User.CreateUserDto

<style>
    /* --- Form Wrapper & Card Styling --- */
    .form-wrapper {
        max-width: 800px;
        margin: 0 auto;
        padding-top: 20px;
    }

    .form-card {
        border: none;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
        overflow: hidden;
    }

    /* --- Premium Header --- */
    .form-header {
        background-color: #f8fafc;
        padding: 24px 30px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .form-header .icon-box {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(59, 130, 246, 0.1); /* Soft Blue */
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .form-header h4 {
            margin: 0;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .form-header p {
            margin: 0;
            font-size: 0.85rem;
            color: #64748b;
        }

    .form-body {
        padding: 35px 30px;
    }

    /* --- Input Styling --- */
    .form-label {
        font-weight: 600;
        color: #334155;
        font-size: 0.85rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .input-wrapper {
        position: relative;
        margin-bottom: 24px;
    }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 41px;
            color: #94a3b8;
            transition: color 0.3s ease;
            font-size: 1.1rem;
            z-index: 5;
        }

    .form-control, .form-select {
        padding: 14px 15px 14px 45px;
        border-radius: 10px;
        border: 2px solid #e2e8f0;
        background-color: #f8fafc;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: none !important;
        color: #0f172a;
    }

        .form-control:focus, .form-select:focus {
            background-color: #ffffff;
            border-color: #3b82f6; /* Blue Focus */
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
        }

    .input-wrapper:focus-within i {
        color: #3b82f6;
    }

    /* --- Validation Styling --- */
    .validation-summary-errors {
        background-color: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 25px;
        font-size: 0.9rem;
    }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 20px;
        }

    /* --- Action Buttons --- */
    .btn-success-custom {
        background-color: #10b981;
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-success-custom:hover {
            background-color: #059669;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(16, 185, 129, 0.25);
        }

    .btn-light {
        background-color: #f1f5f9;
        color: #475569;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .btn-light:hover {
            background-color: #e2e8f0;
            color: #0f172a;
        }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 10px;
    }
</style>

<div class="form-wrapper">
    <div class="card form-card">

        <!-- Premium Header -->
        <div class="form-header">
            <div class="icon-box">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <div>
                <h4>Create New User</h4>
                <p>Register a new staff member or admin account.</p>
            </div>
        </div>

        <!-- Form Body -->
        <div class="form-body">
            <form asp-action="Create" method="post">

                <div asp-validation-summary="All" class="validation-summary-valid" data-valmsg-summary="true"></div>

                <div class="row">
                    <!-- Full Name -->
                    <div class="col-md-6">
                        <div class="input-wrapper">
                            <label asp-for="FullName" class="form-label">Full Name</label>
                            <i class="fa-regular fa-id-card"></i>
                            <input asp-for="FullName" class="form-control" placeholder="e.g., John Doe" autocomplete="off" />
                            <span asp-validation-for="FullName" class="text-danger small mt-1 d-block fw-medium"></span>
                        </div>
                    </div>

                    <!-- Username -->
                    <div class="col-md-6">
                        <div class="input-wrapper">
                            <label asp-for="UserName" class="form-label">Username</label>
                            <i class="fa-regular fa-user"></i>
                            <input asp-for="UserName" class="form-control" placeholder="e.g., johndoe123" autocomplete="off" />
                            <span asp-validation-for="UserName" class="text-danger small mt-1 d-block fw-medium"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Email -->
                    <div class="col-md-6">
                        <div class="input-wrapper">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <i class="fa-regular fa-envelope"></i>
                            <input asp-for="Email" type="email" class="form-control" placeholder="e.g., name@example.com" autocomplete="off" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-medium"></span>
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="col-md-6">
                        <div class="input-wrapper">
                            <label asp-for="Password" class="form-label">Temporary Password</label>
                            <i class="fa-solid fa-lock"></i>
                            <!-- Added type="password" to hide characters -->
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block fw-medium"></span>
                        </div>
                    </div>
                </div>

                <h6 class="text-muted fw-bold mt-3 mb-3 border-bottom pb-2">Role & Assignment</h6>

                <div class="row">
                    <!-- Role Selection -->
                    <div class="col-md-6">
                        <div class="input-wrapper">
                            <label asp-for="Role" class="form-label">System Role</label>
                            <i class="fa-solid fa-shield-halved"></i>
                            <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select">
                                <option value="">-- Select Role --</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small mt-1 d-block fw-medium"></span>
                        </div>
                    </div>

                    <!-- Counter Assignment -->
                    <div class="col-md-6">
                        <div class="input-wrapper">
                            <label asp-for="CounterId" class="form-label">Assign Counter (Optional)</label>
                            <i class="fa-solid fa-desktop"></i>
                            <select asp-for="CounterId" asp-items="ViewBag.Counters" class="form-select">
                                <option value="">-- No Counter Assigned --</option>
                            </select>
                            <span asp-validation-for="CounterId" class="text-danger small mt-1 d-block fw-medium"></span>
                        </div>
                    </div>
                </div>

                <hr class="mb-4 mt-2" style="border-color: #e2e8f0;" />

                <!-- Action Buttons -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-success-custom">
                        <i class="fa-solid fa-check"></i> Save User
                    </button>
                    <a asp-action="Index" class="btn btn-light">
                        Cancel
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}