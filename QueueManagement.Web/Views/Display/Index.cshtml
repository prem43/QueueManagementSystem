@{
    ViewData["Title"] = "Live Queue Display";
    Layout = null; /* Removes the admin sidebar for a full-screen TV display */
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Live Queue Display</title>

    <!-- Google Fonts: Inter for text, Roboto Mono for numbers -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Roboto+Mono:wght@700&display=swap" rel="stylesheet">

    <!-- Bootstrap & FontAwesome -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); /* Deep sleek dark background */
            font-family: 'Inter', sans-serif;
            color: #f8fafc;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Ambient Background Glow */
        .ambient-glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(79,70,229,0.15) 0%, rgba(0,0,0,0) 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 0;
        }

        /* Header */
        .page-header {
            position: absolute;
            top: 40px;
            text-transform: uppercase;
            letter-spacing: 4px;
            font-weight: 800;
            color: #94a3b8;
            font-size: 1.5rem;
            z-index: 1;
        }

        /* Glassmorphism Card */
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: 900px;
            padding: 60px 40px;
            text-align: center;
            z-index: 1;
            transition: all 0.3s ease;
        }

        /* Now Serving Label */
        .status-badge {
            display: inline-block;
            background: rgba(16, 185, 129, 0.2);
            color: #34d399;
            padding: 10px 24px;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
            border: 1px solid rgba(52, 211, 153, 0.3);
        }

        /* Token Number Typography */
        .token-display {
            font-family: 'Roboto Mono', monospace;
            font-size: 140px;
            font-weight: 700;
            line-height: 1;
            margin: 0 0 20px 0;
            color: #ffffff;
            text-shadow: 0 0 30px rgba(255, 255, 255, 0.2);
        }

        /* Customer & Counter Details */
        .customer-name {
            font-size: 2.5rem;
            font-weight: 600;
            color: #e2e8f0;
            margin-bottom: 25px;
        }

        .counter-box {
            display: inline-block;
            background: linear-gradient(135deg, #4f46e5, #3b82f6);
            padding: 15px 40px;
            border-radius: 16px;
            font-size: 2.2rem;
            font-weight: 800;
            color: white;
            box-shadow: 0 10px 25px rgba(79, 70, 229, 0.4);
            margin-bottom: 25px;
        }

        .category-name {
            font-size: 1.2rem;
            color: #94a3b8;
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Calling Animation */
        .calling-pulse {
            animation: ring-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
            border-color: rgba(79, 70, 229, 0.8);
            box-shadow: 0 0 50px rgba(79, 70, 229, 0.5), inset 0 0 20px rgba(79, 70, 229, 0.2);
        }

        @@keyframes ring-pulse {
            0%, 100%

        {
            transform: scale(1);
        }

        50% {
            transform: scale(1.02);
        }

        }
    </style>
</head>
<body>

    <!-- Subtle Background Glow -->
    <div class="ambient-glow"></div>

    <div class="page-header">
        <i class="fa-solid fa-display me-2"></i> Live Queue Display
    </div>

    <!-- Main Display Card -->
    <div class="glass-card" id="displayCard">

        <div class="status-badge">
            <i class="fa-solid fa-satellite-dish me-2 pulse-icon"></i> Now Serving
        </div>

        <div id="tokenNumber" class="token-display">
            ---
        </div>

        <div id="customerName" class="customer-name">
            Waiting for next token...
        </div>

        <div style="display: none;" id="counterWrapper">
            <div id="counterName" class="counter-box">
                <!-- Counter Name Injected Here -->
            </div>
        </div>

        <div id="categoryName" class="category-name">
            System Standby
        </div>

    </div>

    <!-- SignalR Script -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/queueHub")
            .build();

        connection.on("ReceiveTokenCall", function (tokenNumber, customerName, categoryName, counterName) {

            // 1. Update UI Elements
            document.getElementById("tokenNumber").innerText = tokenNumber;
            document.getElementById("customerName").innerText = customerName || "Customer";
            document.getElementById("categoryName").innerText = categoryName;
            document.getElementById("counterName").innerHTML = `<i class="fa-solid fa-arrow-right-to-bracket me-2"></i> Proceed to ${counterName}`;

            // Show the counter wrapper now that we have data
            document.getElementById("counterWrapper").style.display = "block";

            // 2. Trigger Visual Animation
            const card = document.getElementById("displayCard");
            card.classList.add("calling-pulse");

            // Remove animation after 6 seconds
            setTimeout(() => {
                card.classList.remove("calling-pulse");
            }, 6000);

            // 3. Voice Announcement
            const message = `Token number ${tokenNumber}, ${customerName}. Please proceed to ${counterName}.`;
            const speech = new SpeechSynthesisUtterance(message);

            // Tweak voice settings for better PA system sound
            speech.lang = "en-US";
            speech.rate = 0.9;  // Slightly slower for clarity
            speech.pitch = 1.1; // Slightly higher pitch to cut through room noise

            window.speechSynthesis.speak(speech);
        });

        // Start Connection
        connection.start()
            .then(function () {
                console.log("SignalR Connected to Display Board");
            })
            .catch(function (err) {
                return console.error(err.toString());
            });
    </script>

</body>
</html>