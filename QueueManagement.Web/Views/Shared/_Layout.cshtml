<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Queue Management System</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap & FontAwesome -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        :root {
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --sidebar-bg: #111827;
            --sidebar-item-hover: #1f2937;
            --text-muted: #9ca3af;
            --text-light: #f9fafb;
            --bg-body: #f3f4f6;
        }

        body {
            overflow-x: hidden;
            background-color: var(--bg-body);
            font-family: 'Inter', sans-serif;
            color: #1f2937;
        }

        /* --- Sidebar Styling --- */
        .sidebar {
            height: 100vh;
            width: 260px;
            position: fixed;
            top: 0;
            left: 0;
            overflow-y: auto;
            background-color: var(--sidebar-bg);
            padding-top: 25px;
            box-shadow: 4px 0 10px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
        }

        .sidebar-logo {
            text-align: center;
            color: var(--text-light);
            margin-bottom: 40px;
            padding: 0 20px;
        }

            .sidebar-logo .icon-box {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 50px;
                height: 50px;
                background: linear-gradient(135deg, var(--primary-color), #818cf8);
                border-radius: 12px;
                margin-bottom: 15px;
                font-size: 24px;
                color: white;
                box-shadow: 0 4px 15px rgba(79, 70, 229, 0.4);
            }

            .sidebar-logo h4 {
                font-weight: 700;
                margin: 0;
                letter-spacing: -0.5px;
            }

            .sidebar-logo small {
                color: var(--text-muted);
                font-weight: 500;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .sidebar-nav {
            padding: 0 15px;
            flex-grow: 1;
        }

        .sidebar a {
            padding: 12px 18px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-size: 15px;
            font-weight: 500;
        }

            .sidebar a i {
                margin-right: 12px;
                font-size: 18px;
                width: 20px;
                text-align: center;
                transition: color 0.3s;
            }

            .sidebar a:hover {
                background-color: var(--sidebar-item-hover);
                color: var(--text-light);
                transform: translateX(5px);
            }

                .sidebar a:hover i {
                    color: var(--primary-color);
                }

        .logout-btn {
            margin: 15px;
            background-color: rgba(239, 68, 68, 0.1);
            color: #ef4444 !important;
            border-radius: 8px;
        }

            .logout-btn:hover {
                background-color: #ef4444 !important;
                color: white !important;
                transform: translateY(-2px) !important;
            }

        /* --- Main Content & Navbar --- */
        .content {
            margin-left: 260px;
            padding: 25px 30px;
            min-height: 100vh;
        }

        .navbar-custom {
            background-color: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 15px 25px;
            margin-bottom: 30px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            position: sticky;
            top: 25px;
            z-index: 100;
        }

        .navbar-title {
            font-weight: 600;
            color: #111827;
            font-size: 1.25rem;
            margin: 0;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-info {
            text-align: right;
            line-height: 1.2;
        }

        .user-name {
            font-weight: 600;
            color: #374151;
            font-size: 0.95rem;
        }

        .role-badge {
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .user-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background-color: var(--primary-color);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
        }

        /* --- Responsive Design --- */
        @@media (max-width: 768px) {
            .sidebar
        {
            width: 70px;
            padding-top: 15px;
        }

        .sidebar-logo h4, .sidebar-logo small, .sidebar span.nav-text {
            display: none;
        }

        .sidebar a {
            justify-content: center;
            padding: 12px;
        }

            .sidebar a i {
                margin-right: 0;
            }

        .content {
            margin-left: 70px;
            padding: 15px;
        }

        .navbar-title {
            display: none;
        }

        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <div class="icon-box">
                <i class="fa-solid fa-users-line"></i>
            </div>
            <h4>Queue System</h4>
            <small>Management Portal</small>
        </div>

        <div class="sidebar-nav">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Dashboard" asp-action="Index">
                    <i class="fa fa-chart-pie"></i>
                    <span class="nav-text">Dashboard</span>
                </a>

                <a asp-controller="Category" asp-action="Index">
                    <i class="fa fa-folder-open"></i>
                    <span class="nav-text">Categories</span>
                </a>

                <a asp-controller="SubCategory" asp-action="Index">
                    <i class="fa fa-layer-group"></i>
                    <span class="nav-text">SubCategories</span>
                </a>

                <a asp-controller="Counter" asp-action="Index">
                    <i class="fa fa-desktop"></i>
                    <span class="nav-text">Counters</span>
                </a>

                <a asp-controller="User" asp-action="Index">
                    <i class="fa fa-user-shield"></i>
                    <span class="nav-text">Users</span>
                </a>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
            {
                <a asp-controller="Token" asp-action="Index">
                    <i class="fa fa-ticket-alt"></i>
                    <span class="nav-text">Tokens</span>
                </a>

                <a asp-controller="Display" asp-action="Index">
                    <i class="fa fa-tv"></i>
                    <span class="nav-text">Display Board</span>
                </a>
            }
        </div>

        <a asp-controller="Account" asp-action="Logout" class="logout-btn">
            <i class="fa fa-sign-out-alt"></i>
            <span class="nav-text">Logout</span>
        </a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content">
        <!-- TOP NAVBAR -->
        <div class="navbar-custom d-flex justify-content-between align-items-center">
            <div>
                <h4 class="navbar-title">
                    <i class="fa-solid fa-bars-staggered me-2 text-muted"></i>
                    Queue Management System
                </h4>
            </div>

            <div class="user-profile">
                <div class="user-info">
                    <div class="user-name">
                        @(string.IsNullOrEmpty(User.Identity?.Name) ? "Welcome, User" : User.Identity?.Name)
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <span class="badge bg-danger role-badge shadow-sm">Admin</span>
                    }
                    else if (User.IsInRole("Staff"))
                    {
                        <span class="badge bg-primary role-badge shadow-sm" style="background-color: var(--primary-color) !important;">Staff</span>
                    }
                </div>

                <!-- User Avatar -->
                <div class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
            </div>
        </div>

        <!-- RENDER BODY -->
        <main>
            @RenderBody()
        </main>
    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>