<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        Queue Management System
    </title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>

        body {
            overflow-x: hidden;
            background-color: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .sidebar {
            height: 100vh;
            width: 250px;
            position: fixed;
            top: 0;
            left: 0;
            overflow-y: auto;
            background-color: #212529;
            padding-top: 20px;
        }

        .sidebar-logo {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }

            .sidebar-logo h3 {
                font-weight: bold;
            }

        .sidebar a {
            padding: 14px 20px;
            display: block;
            color: #ced4da;
            text-decoration: none;
            transition: 0.3s;
            font-size: 15px;
        }

            .sidebar a i {
                margin-right: 10px;
            }

            .sidebar a:hover {
                background-color: #0d6efd;
                color: white;
            }

        .content {
            margin-left: 250px;
            padding: 20px;
        }

        .navbar-custom {
            background-color: white;
            border-radius: 10px;
            padding: 15px 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .dashboard-card {
            border-radius: 12px;
        }

        .role-badge {
            font-size: 13px;
        }

    </style>

</head>

<body>

    <div class="sidebar">

        <div class="sidebar-logo">

            <h3>
                Queue System
            </h3>

            <small>
                Management Portal
            </small>

        </div>

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Dashboard"
               asp-action="Index">

                <i class="fa fa-chart-line"></i>
                Dashboard

            </a>

            <a asp-controller="Category"
               asp-action="Index">

                <i class="fa fa-folder"></i>
                Categories

            </a>

            <a asp-controller="SubCategory"
               asp-action="Index">

                <i class="fa fa-layer-group"></i>
                SubCategories

            </a>

            <a asp-controller="Counter"
               asp-action="Index">

                <i class="fa fa-desktop"></i>
                Counters

            </a>

            <a asp-controller="User"
               asp-action="Index">

                <i class="fa fa-users"></i>
                Users

            </a>
        }

        @if (User.IsInRole("Admin")
                || User.IsInRole("Staff"))
        {
            <a asp-controller="Token"
               asp-action="Index">

                <i class="fa fa-ticket"></i>
                Tokens

            </a>

            <a asp-controller="Display"
               asp-action="Index">

                <i class="fa fa-tv"></i>
                Display Board

            </a>
        }

        <a asp-controller="Account"
           asp-action="Logout">

            <i class="fa fa-sign-out-alt"></i>
            Logout

        </a>

    </div>

    <div class="content">

        <div class="navbar-custom
                    d-flex
                    justify-content-between
                    align-items-center">

            <div>

                <h4 class="mb-0">
                    Queue Management System
                </h4>

            </div>

            <div class="text-end">

                <strong>
                    @User.Identity?.Name
                </strong>

                <br />

                @if (User.IsInRole("Admin"))
                {
                    <span class="badge bg-danger role-badge">

                        Admin

                    </span>
                }
                else if (User.IsInRole("Staff"))
                {
                    <span class="badge bg-primary role-badge">

                        Staff

                    </span>
                }

            </div>

        </div>

        <main>

            @RenderBody()

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
    </script>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js">
    </script>

    @await RenderSectionAsync(
    "Scripts",
        required: false)

</body>

</html>