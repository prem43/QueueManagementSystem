@model QueueManagement.Application.DTOs.Token.TransferTokenDto

<style>
    .form-wrapper {
        max-width: 600px;
        margin: 0 auto;
        padding-top: 20px;
    }

    .form-card {
        border: none;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .form-header {
        background-color: #fffbeb;
        padding: 24px 30px;
        border-bottom: 1px solid #fde68a;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .form-header .icon-box {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(245, 158, 11, 0.2);
            color: #d97706;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .form-header h4 {
            margin: 0;
            font-weight: 700;
            color: #92400e;
        }

        .form-header p {
            margin: 0;
            font-size: 0.85rem;
            color: #b45309;
        }

    .form-body {
        padding: 35px 30px;
    }

    .form-label {
        font-weight: 600;
        color: #374151;
        font-size: 0.85rem;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .input-wrapper {
        position: relative;
        margin-bottom: 24px;
    }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 41px;
            color: #9ca3af;
            font-size: 1.1rem;
            z-index: 5;
        }

    .form-control, .form-select {
        padding: 14px 15px 14px 45px;
        border-radius: 10px;
        border: 2px solid #e5e7eb;
        background-color: #f9fafb;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            background-color: #ffffff;
            border-color: #f59e0b;
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
        }

    textarea.form-control {
        padding-left: 15px;
        min-height: 100px;
    }

    .btn-warning-custom {
        background-color: #f59e0b;
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-warning-custom:hover {
            background-color: #d97706;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(245, 158, 11, 0.3);
            color: white;
        }
</style>

<div class="form-wrapper">
    <div class="card form-card">
        <div class="form-header">
            <div class="icon-box"><i class="fa-solid fa-arrow-right-arrow-left"></i></div>
            <div>
                <h4>Transfer Token</h4>
                <p>Move this token to a different category.</p>
            </div>
        </div>

        <div class="form-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm rounded-3 mb-4"><i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]</div>
            }

            <form asp-action="Transfer" method="post">
                <input type="hidden" asp-for="TokenId" />
                <div asp-validation-summary="All" class="text-danger mb-3 small fw-bold"></div>

                <div class="input-wrapper">
                    <label class="form-label">Transfer To Category</label>
                    <i class="fa-solid fa-folder-tree"></i>
                    <select asp-for="ToCategoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="0">-- Select Destination Category --</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label">Transfer Reason</label>
                    <textarea asp-for="TransferReason" class="form-control" placeholder="Briefly explain why this token is being transferred..."></textarea>
                </div>

                <hr class="mb-4" style="border-color: #e5e7eb;" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-warning-custom"><i class="fa-solid fa-paper-plane me-2"></i> Submit Transfer</button>
                    <a asp-action="Index" class="btn btn-light fw-bold text-muted px-4 py-2 rounded-3">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}