@model IEnumerable<QueueManagement.Application.DTOs.Category.CategoryDto>

<h2>Categories</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Create Category
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Prefix</th>
            <th>Description</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Prefix</td>
                <td>@item.Description</td>
                <td>
                    @(item.IsActive ? "Active" : "Inactive")
                </td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>
                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>