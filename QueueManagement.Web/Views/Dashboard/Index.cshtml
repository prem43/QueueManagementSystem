@model QueueManagement.Application.DTOs.Dashboard.DashboardDto

<style>
    /* --- Dashboard Specific Styles --- */
    .dashboard-header {
        font-weight: 700;
        color: #111827;
        letter-spacing: -0.5px;
    }

    /* Stat Cards */
    .stat-card {
        border: none;
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 20px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        .stat-card .card-body {
            padding: 24px;
            display: flex;
            align-items: center;
        }

    /* Icon Wrappers */
    .icon-wrapper {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    /* Color Themes */
    .theme-blue {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }

    .theme-green {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .theme-purple {
        background: rgba(139, 92, 246, 0.1);
        color: #8b5cf6;
    }

    .theme-red {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .theme-orange {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }

    .theme-teal {
        background: rgba(20, 184, 166, 0.1);
        color: #14b8a6;
    }

    /* Text Formatting */
    .stat-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        line-height: 1.2;
    }

    /* Secondary Cards (Wait Time, Transfers) */
    .secondary-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        background: linear-gradient(135deg, #ffffff 0%, #f9fafb 100%);
    }

        .secondary-card .card-header {
            background-color: transparent;
            border-bottom: 1px solid #f3f4f6;
            padding: 16px 24px;
            font-weight: 600;
            color: #374151;
            font-size: 1.05rem;
        }

        .secondary-card h1 {
            font-weight: 700;
            color: #111827;
        }

    /* Active Tickets List */
    .live-indicator {
        display: inline-block;
        width: 10px;
        height: 10px;
        background-color: #10b981;
        border-radius: 50%;
        margin-right: 8px;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%

    {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }

    70% {
        box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
    }

    100% {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
    }

    }

    .ticket-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .ticket-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        font-weight: 600;
        color: #374151;
        transition: background 0.2s;
    }

        .ticket-item:hover {
            background: #f3f4f6;
        }

    .ticket-icon {
        color: #4f46e5;
        margin-right: 15px;
        font-size: 1.2rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="dashboard-header">Overview Dashboard</h2>
    <span class="text-muted"><i class="fa-regular fa-calendar me-2"></i>@DateTime.Now.ToString("dd MMM yyyy")</span>
</div>

<!-- Primary KPIs Row -->
<div class="row g-4">

    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="card-body">
                <div class="icon-wrapper theme-blue">
                    <i class="fa-solid fa-hourglass-half"></i>
                </div>
                <div class="ms-4">
                    <p class="stat-title">Pending Tokens</p>
                    <h3 class="stat-value">@Model.PendingTokens</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="card-body">
                <div class="icon-wrapper theme-green">
                    <i class="fa-solid fa-user-check"></i>
                </div>
                <div class="ms-4">
                    <p class="stat-title">Serving Tokens</p>
                    <h3 class="stat-value">@Model.ServingTokens</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="card-body">
                <div class="icon-wrapper theme-purple">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div class="ms-4">
                    <p class="stat-title">Completed</p>
                    <h3 class="stat-value">@Model.CompletedTokens</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="card-body">
                <div class="icon-wrapper theme-red">
                    <i class="fa-solid fa-circle-xmark"></i>
                </div>
                <div class="ms-4">
                    <p class="stat-title">Skipped</p>
                    <h3 class="stat-value">@Model.SkippedTokens</h3>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Secondary KPIs Row -->
<div class="row g-4 mt-1">

    <div class="col-md-6">
        <div class="card secondary-card h-100">
            <div class="card-header d-flex align-items-center">
                <i class="fa-regular fa-clock me-2 text-warning"></i> Average Wait Time
            </div>
            <div class="card-body d-flex align-items-center">
                <div class="icon-wrapper theme-orange me-4">
                    <i class="fa-solid fa-stopwatch"></i>
                </div>
                <div>
                    <h1 class="mb-0">@Model.AverageWaitTimeMinutes <span class="text-muted fs-5 fw-normal">min</span></h1>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card secondary-card h-100">
            <div class="card-header d-flex align-items-center">
                <i class="fa-solid fa-right-left me-2 text-info"></i> Transferred Tokens
            </div>
            <div class="card-body d-flex align-items-center">
                <div class="icon-wrapper theme-teal me-4">
                    <i class="fa-solid fa-shuffle"></i>
                </div>
                <div>
                    <h1 class="mb-0">@Model.TransferredTokens</h1>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Live Serving Tokens Section -->
<div class="mt-4 pt-2">
    <div class="card secondary-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <span class="live-indicator"></span> Current Serving Tokens
            </div>
            <span class="badge bg-light text-dark border">@Model.CurrentServingTokens.Count() Active</span>
        </div>

        <div class="card-body p-4">
            @if (Model.CurrentServingTokens.Any())
            {
                <div class="ticket-list">
                    @foreach (var token in Model.CurrentServingTokens)
                    {
                        <div class="ticket-item shadow-sm">
                            <i class="fa-solid fa-ticket ticket-icon"></i>
                            <span class="fs-5">Token <span class="text-primary">#@token</span></span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="icon-wrapper theme-blue mx-auto mb-3" style="opacity: 0.5;">
                        <i class="fa-solid fa-mug-hot"></i>
                    </div>
                    <h5 class="text-muted fw-normal">No active serving tokens at the moment.</h5>
                    <p class="text-muted small">Wait for a new ticket to be called.</p>
                </div>
            }
        </div>
    </div>
</div>